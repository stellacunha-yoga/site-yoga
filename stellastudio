<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stella Studio — Wellness · Fitness · Yoga</title>
    <style>
        :root {
            --gold: #C9A460;
            --gold-light: #F0D080;
            --gold-dim: rgba(201, 164, 96, 0.35);
            --dark: #111111;
            --dark-section: #161616;
            --text-main: #e8e0d0;
            --text-soft: #a89878;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Georgia', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: var(--text-main);
            background: var(--dark);
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

        /* LOGO BANNER */
        .logo-banner {
            width: 100%;
            display: block;
            line-height: 0;
            background: #111;
        }
        .logo-banner img {
            width: 100%;
            height: auto;
            display: block;
        }

        /* HERO TEXT */
        .hero-text {
            background: linear-gradient(160deg, #0d0d0d 0%, #1a1510 60%, #111 100%);
            text-align: center;
            padding: 50px 20px 60px;
            border-bottom: 1px solid var(--gold-dim);
            position: relative;
        }
        .hero-text::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 30% 40%, rgba(201,164,96,0.07) 0%, transparent 50%),
                        radial-gradient(circle at 70% 60%, rgba(201,164,96,0.04) 0%, transparent 40%);
            pointer-events: none;
        }
        .hero-text h1 {
            font-size: 3em;
            font-weight: 300;
            letter-spacing: 3px;
            color: var(--gold-light);
            margin-bottom: 16px;
            animation: fadeInUp 1s ease-out;
        }
        .hero-text p {
            font-size: 1.2em;
            color: var(--text-soft);
            margin-bottom: 32px;
            animation: fadeInUp 1s ease-out 0.3s both;
        }
        .cta-button {
            display: inline-block;
            background: transparent;
            color: var(--gold);
            padding: 14px 42px;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            border: 2px solid var(--gold);
            animation: fadeInUp 1s ease-out 0.6s both;
        }
        .cta-button:hover {
            background: var(--gold);
            color: #111;
            box-shadow: 0 0 30px rgba(201,164,96,0.4);
            transform: translateY(-2px);
        }

        /* SECTION */
        .section {
            padding: 60px 0;
            background: var(--dark-section);
            margin: 40px 0;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.4);
            border: 1px solid rgba(201,164,96,0.1);
        }
        .section h2 {
            font-size: 2.4em;
            text-align: center;
            margin-bottom: 40px;
            color: var(--gold-light);
            font-weight: 300;
            letter-spacing: 2px;
        }

        /* CARDS */
        .yoga-practices {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
            gap: 25px;
            margin-top: 40px;
        }
        .practice-card {
            background: #1e1e1e;
            padding: 25px;
            border-radius: 15px;
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid rgba(201,164,96,0.15);
        }
        .practice-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(201,164,96,0.15);
            border-color: var(--gold-dim);
        }
        .practice-card h3 { color: var(--gold); margin-bottom: 12px; font-size: 1.2em; }
        .practice-card p { color: var(--text-soft); font-size: 0.95em; }
        .practice-photo {
            width: 100%; height: 200px;
            border-radius: 10px; margin-bottom: 20px;
            overflow: hidden; border: 1px solid rgba(201,164,96,0.2);
        }
        .practice-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

        /* EBOOK */
        .ebook-section {
            background: linear-gradient(135deg, #161208 0%, #1a150a 100%);
            padding: 70px 0;
            border-top: 1px solid var(--gold-dim);
            border-bottom: 1px solid var(--gold-dim);
            position: relative;
        }
        .ebook-section::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(circle at 20% 50%, rgba(201,164,96,0.07) 0%, transparent 50%);
            pointer-events: none;
        }
        .ebook-content {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 40px; align-items: center;
            max-width: 1000px; margin: 0 auto;
            position: relative; z-index: 2;
        }
        .ebook-cover {
            width: 100%; max-width: 300px; height: 400px;
            border-radius: 15px; overflow: hidden;
            border: 2px solid var(--gold-dim);
            box-shadow: 0 10px 40px rgba(0,0,0,0.6);
        }
        .ebook-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .ebook-info h3 {
            font-size: 2.2em; margin-bottom: 20px;
            font-weight: 300; color: var(--gold-light); letter-spacing: 1px;
        }
        .ebook-info p { color: var(--text-soft); }
        .ebook-benefits { list-style: none; text-align: left; margin: 20px 0; }
        .ebook-benefits li {
            padding: 8px 0; padding-left: 25px;
            position: relative; color: var(--text-main);
        }
        .ebook-benefits li::before { content: '✔'; position: absolute; left: 0; color: var(--gold); }
        .price { font-size: 2.5em; font-weight: 600; margin: 20px 0; color: var(--gold); }
        .payment-methods { display: flex; justify-content: center; gap: 20px; margin: 20px 0; }
        .payment-method {
            background: rgba(201,164,96,0.08); padding: 10px 20px;
            border-radius: 10px; border: 1px solid var(--gold-dim);
        }
        .payment-method a { color: var(--gold); text-decoration: none; font-weight: 600; }

        /* PERSONAL */
        .personal-section {
            background: linear-gradient(135deg, #131313 0%, #1a1a1a 100%);
            padding: 70px 0;
            border-top: 1px solid rgba(201,164,96,0.1);
            position: relative;
        }
        .personal-section::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(circle at 80% 30%, rgba(201,164,96,0.06) 0%, transparent 50%);
            pointer-events: none;
        }
        .personal-content {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 50px; align-items: center;
            position: relative; z-index: 2;
        }
        .personal-photo {
            width: 100%; height: 400px;
            border-radius: 15px; overflow: hidden;
            border: 2px solid var(--gold-dim);
            box-shadow: 0 10px 40px rgba(0,0,0,0.6);
        }
        .personal-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .personal-section h2 {
            color: var(--gold-light); font-size: 2em;
            font-weight: 300; letter-spacing: 1px; margin-bottom: 15px;
        }
        .personal-section h3 { color: var(--gold); }
        .info-box {
            background: rgba(201,164,96,0.05);
            padding: 30px; border-radius: 15px; margin: 20px 0;
            border: 1px solid rgba(201,164,96,0.2);
        }
        .info-box ul { list-style: none; text-align: left; }
        .info-box li { padding: 6px 0; color: var(--text-main); }
        .price-small { font-size: 1.05em; color: var(--text-soft); margin-top: 15px; }
        .price-main { font-size: 2.2em; font-weight: 600; margin-top: 8px; color: var(--gold); }

        /* CONTACT */
        .contact-info {
            background: #0e0e0e; padding: 50px 0;
            text-align: center; border-top: 1px solid var(--gold-dim);
        }
        .contact-info h2 {
            color: var(--gold-light); font-weight: 300;
            letter-spacing: 2px; margin-bottom: 30px;
        }
        .contact-details {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px; margin-top: 20px;
        }
        .contact-item {
            background: #1a1a1a; padding: 25px;
            border-radius: 12px; border: 1px solid rgba(201,164,96,0.15);
        }
        .contact-item h4 { color: var(--gold); margin-bottom: 10px; }
        .contact-item p { color: var(--text-soft); }
        .contact-item a { color: var(--text-soft); text-decoration: none; font-weight: 500; transition: color 0.2s; }
        .contact-item a:hover { color: var(--gold); }

        /* WHATSAPP */
        .whatsapp-button {
            background: #C9A460; color: #111;
            padding: 15px 30px; text-decoration: none;
            border-radius: 50px; font-weight: 700;
            display: inline-block; transition: all 0.3s ease;
            position: fixed; bottom: 20px; right: 20px;
            z-index: 1000; box-shadow: 0 5px 20px rgba(201,164,96,0.4);
            letter-spacing: 0.5px;
        }
        .whatsapp-button:hover { background: #F0D080; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(201,164,96,0.6); }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 768px) {
            .hero-text h1 { font-size: 2em; }
            .ebook-content, .personal-content {
                grid-template-columns: 1fr; text-align: center;
            }
            .ebook-cover, .personal-photo { max-width: 100%; margin: 0 auto; }
            .contact-details { grid-template-columns: 1fr; }
            .info-box ul { text-align: center; }
        }
    </style>
</head>
